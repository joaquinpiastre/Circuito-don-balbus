# Para desarrollo local: copiá este archivo a .env.local
# (Next.js lee .env.local automáticamente al hacer npm run dev)
#
# Con los valores de abajo la web abre igual; usa horarios/tarifas por defecto.
# Para panel admin y galería necesitás un proyecto en Supabase (ver README).

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Resend (opcional; formulario de contacto por email)
# RESEND_API_KEY=re_xxxx
# CONTACT_EMAIL=contacto@tudominio.com
